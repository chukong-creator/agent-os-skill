#!/bin/sh
branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)
if [ "$branch" = "main" ] && [ "${AGENT_SHIFT_ALLOW_MAIN_COMMIT:-0}" != "1" ]; then
  echo "Agent Shift: direct commits to protected main are blocked." >&2
  echo "Use an agent worktree, or let Codex main explicitly authorize a protocol commit." >&2
  exit 1
fi
